{
    "name": "maiscraft/crypto-hyperf",
    "description": "Hyperf adapter for Maiscraft Crypto - ConfigProvider and DI registration",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "MaisCraft Team",
            "email": "team@mslbit.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "hyperf/framework": "^3.1",
        "hyperf/di": "^3.1",
        "hyperf/command": "^3.1",
        "maiscraft/crypto": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Maiscraft\\CryptoHyperf\\": "src/"
        }
    },
    "extra": {
        "hyperf": {
            "config": "Maiscraft\\CryptoHyperf\\ConfigProvider"
        }
    },
    "keywords": [
        "crypto",
        "hyperf",
        "hash",
        "encrypt"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}